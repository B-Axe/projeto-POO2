import pygame
import sys
import random

pygame.init()

# =========================
# LER CONFIGURAÇÃO
# =========================
def carregar_config(nome_arquivo):

    carros = []
    estrada_x = 100
    estrada_largura = 300

    with open(nome_arquivo, "r") as arquivo:

        for linha in arquivo:

            linha = linha.strip()

            if linha == "" or linha.startswith("#"):
                continue

            if linha.startswith("estrada_x="):
                estrada_x = int(linha.split("=")[1])

            elif linha.startswith("estrada_largura="):
                estrada_largura = int(linha.split("=")[1])

            elif linha.startswith("carro="):
                dados = linha.split("=")[1]
                x, y, r, g, b = map(int, dados.split(","))
                carros.append({"x": x, "y": y, "cor": (r, g, b)})

    return estrada_x, estrada_largura, carros


# =========================
# CLASSE CARRO
# =========================
class Carro:

    def __init__(self, x, y, cor, frenagem=True, frenagem_brusca=False):

        self.x_base = x
        self.y = y
        self.cor = cor

        self.frenagem = frenagem
        self.frenagem_brusca = frenagem_brusca

        self.velocidade_base = random.randint(2, 7)
        self.velocidade_atual = self.velocidade_base

        self.batido = False
        self.tempo_batida = 0

        self.largura = 60
        self.altura = 100

        self.DISTANCIA_FRENAGEM = 150
        self.DISTANCIA_SEGURA = 110
        self.freando = False

    def atualizar(self, tempo_atual, outros_carros):

        # recuperar batida
        if self.batido:
            if tempo_atual - self.tempo_batida > 5000:
                self.batido = False
            else:
                return

        self.freando = False

        # --- SEM FRENAGEM (estrada 2) ---
        if not self.frenagem:
            self.velocidade_atual = self.velocidade_base
            self.y += self.velocidade_atual
            return

        carro_a_frente = self._encontrar_carro_a_frente(outros_carros)

        # --- FRENAGEM BRUSCA (estrada 3) ---
        if self.frenagem_brusca:

            if carro_a_frente is not None:

                distancia = carro_a_frente.y - (self.y + self.altura)

                if distancia < self.DISTANCIA_FRENAGEM:

                    self.freando = True

                    # se o da frente está muito perto: para instantaneamente
                    if distancia <= self.DISTANCIA_SEGURA:
                        self.velocidade_atual = 0
                    else:
                        # fora da zona crítica: diminui proporcionalmente mas rápido
                        fator = (distancia - self.DISTANCIA_SEGURA) / (
                            self.DISTANCIA_FRENAGEM - self.DISTANCIA_SEGURA
                        )
                        self.velocidade_atual = max(
                            0,
                            carro_a_frente.velocidade_atual
                            + fator * (self.velocidade_base - carro_a_frente.velocidade_atual),
                        )
                else:
                    # caminho livre → volta à velocidade base instantaneamente
                    self.velocidade_atual = self.velocidade_base

            else:
                self.velocidade_atual = self.velocidade_base

            self.y += self.velocidade_atual
            return

        # --- FRENAGEM SUAVE (estrada 1) ---
        if carro_a_frente is not None:

            distancia = carro_a_frente.y - (self.y + self.altura)

            if distancia < self.DISTANCIA_FRENAGEM:

                self.freando = True

                if distancia <= self.DISTANCIA_SEGURA:
                    vel_alvo = max(0, carro_a_frente.velocidade_atual)
                else:
                    fator = (distancia - self.DISTANCIA_SEGURA) / (
                        self.DISTANCIA_FRENAGEM - self.DISTANCIA_SEGURA
                    )
                    vel_alvo = max(
                        0,
                        carro_a_frente.velocidade_atual
                        + fator * (self.velocidade_base - carro_a_frente.velocidade_atual),
                    )

                if self.velocidade_atual > vel_alvo:
                    self.velocidade_atual = max(vel_alvo, self.velocidade_atual - 0.3)
                else:
                    self.velocidade_atual = min(vel_alvo, self.velocidade_atual + 0.15)

            else:
                self.velocidade_atual = min(self.velocidade_base, self.velocidade_atual + 0.15)
        else:
            self.velocidade_atual = min(self.velocidade_base, self.velocidade_atual + 0.15)

        self.y += self.velocidade_atual

    def _encontrar_carro_a_frente(self, outros_carros):

        ALCANCE = self.DISTANCIA_FRENAGEM + self.altura + 20
        candidato = None
        menor = float("inf")

        for outro in outros_carros:

            if outro is self:
                continue

            if abs(outro.x_base - self.x_base) >= 20:
                continue

            dist = outro.y - (self.y + self.altura)

            if 0 <= dist < ALCANCE and dist < menor:
                menor = dist
                candidato = outro

        return candidato

    def trocar_velocidade(self):
        self.velocidade_base = random.randint(2, 7)

    def get_rect(self):
        return pygame.Rect(self.x_base, self.y, self.largura, self.altura)


# =========================
# CLASSE ESTRADA
# =========================
class Estrada:

    def __init__(self, nome_arquivo, offset_x_tela, com_frenagem=True, frenagem_brusca=False):

        self.offset_x = offset_x_tela

        estrada_x, estrada_largura, carros_cfg = carregar_config(nome_arquivo)

        self.estrada_x_local = estrada_x
        self.estrada_largura = estrada_largura

        self.carros = [
            Carro(c["x"], c["y"], c["cor"],
                  frenagem=com_frenagem,
                  frenagem_brusca=frenagem_brusca)
            for c in carros_cfg
        ]
        self.carro_ref = self.carros[0] if self.carros else None

        self.zoom = 1.0
        self.tempo_troca = pygame.time.get_ticks()

    def calcular_zoom(self):

        if not self.carro_ref or len(self.carros) < 2:
            self.zoom = 1.0
            return

        maior = max(abs(c.y - self.carro_ref.y) for c in self.carros)

        if maior > 300:
            self.zoom = max(0.3, 1 - maior / 1500)
        else:
            self.zoom = 1.0

    def zoom_y(self, y, centro_y):
        return centro_y + (y - centro_y) * self.zoom

    def zoom_x(self, x, centro_x):
        return centro_x + (x - centro_x) * self.zoom

    def verificar_colisoes(self, tempo_atual):

        for c1 in self.carros:

            if c1.batido:
                continue

            for c2 in self.carros:

                if c1 is c2:
                    continue

                if abs(c1.x_base - c2.x_base) >= 20:
                    continue

                if c1.get_rect().colliderect(c2.get_rect()):

                    if c1.y < c2.y:
                        c1.batido = True
                        c1.tempo_batida = tempo_atual
                    elif c2.y < c1.y:
                        c2.batido = True
                        c2.tempo_batida = tempo_atual

    def atualizar(self, tempo_atual):

        if tempo_atual - self.tempo_troca > 3000:
            for c in self.carros:
                c.trocar_velocidade()
            self.tempo_troca = tempo_atual

        for c in self.carros:
            c.atualizar(tempo_atual, self.carros)

        self.verificar_colisoes(tempo_atual)
        self.calcular_zoom()


# =========================
# CLASSE JOGO
# =========================
class Jogo:

    LARGURA_SLOT = 550
    LARGURA_TELA = LARGURA_SLOT * 2
    ALTURA_TELA  = 800

    VERDE    = (40, 160, 40)
    CINZA    = (70, 70, 70)
    BRANCO   = (255, 255, 255)
    VERMELHO = (255, 0, 0)
    PRETO    = (0, 0, 0)

    def __init__(self):

        self.tela = pygame.display.set_mode((self.LARGURA_TELA, self.ALTURA_TELA))
        pygame.display.set_caption("Duas Estradas")

        self.clock = pygame.time.Clock()
        self.fonte = pygame.font.SysFont("monospace", 13)

        # estrada 1: frenagem suave
        self.estrada1 = Estrada("config1.txt",
                                offset_x_tela=0,
                                com_frenagem=True,
                                frenagem_brusca=False)

        # estrada 2: sem frenagem
        self.estrada2 = Estrada("config2.txt",
                                offset_x_tela=self.LARGURA_SLOT,
                                com_frenagem=False,
                                frenagem_brusca=False)

        self.estradas = [self.estrada1, self.estrada2]

    # =========================
    # DESENHAR UMA ESTRADA
    # =========================
    def desenhar_estrada(self, estrada, superficie):

        W = self.LARGURA_SLOT
        H = self.ALTURA_TELA

        superficie.fill(self.VERDE)

        if not estrada.carro_ref:
            return

        centro_y = H // 2
        centro_x = W // 2

        ex = estrada.zoom_x(estrada.estrada_x_local, centro_x)
        ew = estrada.estrada_largura * estrada.zoom

        pygame.draw.rect(superficie, self.CINZA, (int(ex), 0, int(ew), H))

        NUM_FAIXAS = 7
        lf = estrada.estrada_largura / NUM_FAIXAS

        for f in range(1, NUM_FAIXAS):

            xl = estrada.zoom_x(estrada.estrada_x_local + f * lf, centro_x)

            for i in range(-H * 2, H * 2, 80):

                ym = i + (estrada.carro_ref.y % 80)
                yt = estrada.zoom_y(ym, centro_y)

                pygame.draw.rect(
                    superficie, self.BRANCO,
                    (int(xl), int(yt), int(8 * estrada.zoom), int(40 * estrada.zoom)),
                )

        for carro in estrada.carros:

            base_y = centro_y - (carro.y - estrada.carro_ref.y)
            tela_y = estrada.zoom_y(base_y, centro_y)
            tela_x = estrada.zoom_x(carro.x_base, centro_x)

            self._desenhar_carro(superficie, carro, tela_x, tela_y, estrada.zoom)

    def _desenhar_carro(self, surf, carro, x, y, zoom):

        larg = int(60 * zoom)
        alt  = int(100 * zoom)
        cor  = self.VERMELHO if carro.batido else carro.cor

        pygame.draw.rect(surf, cor, (int(x), int(y), larg, alt))

        for rx in (10, 50):
            pygame.draw.circle(
                surf, self.PRETO,
                (int(x + rx * zoom), int(y + 90 * zoom)),
                int(10 * zoom)
            )

        for fx in (15, 45):
            pygame.draw.circle(
                surf, (255, 255, 0),
                (int(x + fx * zoom), int(y + 10 * zoom)),
                int(5 * zoom)
            )

        if carro.freando and not carro.batido:
            fy = int(y + alt - int(8 * zoom))
            for bx in (5, 40):
                pygame.draw.rect(
                    surf, self.VERMELHO,
                    (int(x + bx * zoom), fy, int(15 * zoom), int(6 * zoom))
                )

        txt = self.fonte.render(f"{carro.velocidade_atual:.1f}", True, self.BRANCO)
        surf.blit(txt, (int(x + 5 * zoom), int(y) - 16))

    # =========================
    # LOOP PRINCIPAL
    # =========================
    def rodar(self):

        surfs = [
            pygame.Surface((self.LARGURA_SLOT, self.ALTURA_TELA))
            for _ in self.estradas
        ]

        rodando = True

        while rodando:

            for ev in pygame.event.get():
                if ev.type == pygame.QUIT:
                    rodando = False

            tempo_atual = pygame.time.get_ticks()

            for estrada in self.estradas:
                estrada.atualizar(tempo_atual)

            self.tela.fill(self.VERDE)

            for estrada, surf in zip(self.estradas, surfs):
                self.desenhar_estrada(estrada, surf)
                self.tela.blit(surf, (estrada.offset_x, 0))

            pygame.draw.line(
                self.tela, self.PRETO,
                (self.LARGURA_SLOT, 0),
                (self.LARGURA_SLOT, self.ALTURA_TELA),
                3
            )

            pygame.display.update()
            self.clock.tick(60)

        pygame.quit()
        sys.exit()


# =========================
# EXECUÇÃO
# =========================
if __name__ == "__main__":
    Jogo().rodar()
